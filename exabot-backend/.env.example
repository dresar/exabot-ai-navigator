# ============================================================
# ExaBot Backend — Environment Configuration
# Copy this file to .env and fill in real values
# ============================================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/exabot?ssl=require

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-character-random-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-fernet-key

# --- OpenAI Seed Keys (bootstrapped on startup, more managed in DB) ---
OPENAI_API_KEY_1=sk-proj-...
OPENAI_API_KEY_2=sk-proj-...

# --- External APIs ---
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
NEWS_API_KEY=your-newsapi-key
COINGECKO_API_KEY=your-coingecko-key
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# --- File Storage (Cloudflare R2 or AWS S3) ---
S3_BUCKET_NAME=exabot-datasets
S3_ENDPOINT_URL=https://account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=auto

# --- Application ---
ENVIRONMENT=development
DEBUG=true
APP_NAME=ExaBot
APP_VERSION=1.0.0
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://exabot.ai

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
