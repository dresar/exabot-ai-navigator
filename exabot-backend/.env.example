# Copy to .env and fill values
#
# WAJIB pakai postgresql+asyncpg:// (bukan postgresql:// saja — akan error "psycopg2 is not async")

DATABASE_URL=postgresql+asyncpg://user:pass@host.neon.tech/exabot?ssl=require

SECRET_KEY=change-me-64-hex-chars-minimum
ENCRYPTION_KEY=fernet-key-from-python-cryptography

# OpenAI (optional if using unified LLM only)
OPENAI_API_KEY_1=
OPENAI_API_KEY_2=

# Unified LLM (OpenAI-compatible: POST {LLM_BASE_URL}/chat/completions)
LLM_PROVIDER=unified
LLM_BASE_URL=https://one.apprentice.cyou/api/v1
LLM_API_KEY=YOUR_UNIFIED_API_KEY
LLM_MODEL=gemini-2.5-flash

POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
NEWS_API_KEY=

# Hanya dipakai jika menjalankan worker Celery (docker-compose). API tidak membutuhkan Redis.
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Include frontend dev URL
CORS_ORIGINS=http://localhost:8083,http://localhost:5173

# Dev user & login cepat (satu sumber — bisa diubah di app.config / di sini)
# AUTO_SEED_DEV_USER_ON_STARTUP=true   → buat user di DB saat API start (non-production)
# AUTH_DEV_QUICK_LOGIN=true            → izinkan POST /auth/dev-login
# DEV_QUICK_LOGIN_EMAIL=dev@localhost  → email user untuk "Login cepat" di UI dev
# DEV_SEED_EMAIL=dev@localhost
# DEV_SEED_USERNAME=dev
# DEV_SEED_PASSWORD=DevPass123!
